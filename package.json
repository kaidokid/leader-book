{
  "name": "leader-book-app-static",
  "version": "1.0.0",
  "description": "管理者精读萃取 - 纯前端版本，无需服务器",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "prebuild": "node -e \"if(process.platform!=='win32'){require('child_process').execSync('chmod +x node_modules/.bin/*',{stdio:'ignore'})}\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "zustand": "^5.0.3",
    "lucide-react": "^0.511.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "rehype-raw": "^7.0.0",
    "mermaid": "^10.9.1",
    "pdfjs-dist": "^4.9.155",
    "jszip": "^3.10.1",
    "iconv-lite": "^0.6.3",
    "idb": "^8.0.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^5.1.4",
    "typescript": "^5.7.2",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}
